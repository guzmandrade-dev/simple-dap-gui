{
  "name": "simple-dap-gui",
  "version": "0.3.2",
  "description": "A standalone DAP client GUI app using Electron + React + PrismJS",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build && electron-builder",
    "build:renderer": "vite build",
    "build:icons": "node scripts/build-icons.js",
    "lint": "eslint src --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "preview": "vite preview",
    "postinstall": "electron-builder install-app-deps",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui"
  },
  "keywords": [
    "electron",
    "react",
    "dap",
    "debugger",
    "prismjs",
    "xdebug"
  ],
  "author": {
    "name": "guzmandrade-dev",
    "email": "117118816+guzmandrade-dev@users.noreply.github.com"
  },
  "license": "MIT",
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/adm-zip": "^0.5.5",
    "@types/node": "^20.10.4",
    "@types/prismjs": "^1.26.6",
    "@types/react": "^18.2.43",
    "@types/react-dom": "^18.2.17",
    "@typescript-eslint/eslint-plugin": "^6.14.0",
    "@typescript-eslint/parser": "^6.14.0",
    "@vitejs/plugin-react": "^4.2.1",
    "@vitest/ui": "^4.1.8",
    "autoprefixer": "^10.4.16",
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1",
    "eslint": "^8.55.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.5",
    "jsdom": "^29.1.1",
    "postcss": "^8.4.32",
    "sharp": "^0.35.2",
    "tailwindcss": "^3.3.6",
    "typescript": "^5.3.3",
    "vite": "^5.0.8",
    "vite-plugin-electron": "^0.28.0",
    "vite-plugin-electron-renderer": "^0.14.5",
    "vitest": "^4.1.8"
  },
  "dependencies": {
    "@vscode/debugprotocol": "^1.66.0",
    "adm-zip": "^0.5.10",
    "prismjs": "^1.30.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "zustand": "^4.4.7"
  },
  "build": {
    "appId": "com.guzmandrade.simple-dap-gui",
    "productName": "simple-dap-gui",
    "directories": {
      "output": "dist"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "assets/**/*"
    ],
    "icon": "assets/icon.png",
    "mac": {
      "target": [
        "dmg",
        "zip"
      ]
    },
    "linux": {
      "target": [
        "AppImage",
        "deb",
        "tar.gz",
        "tar.xz"
      ],
      "category": "Development"
    },
    "win": {
      "target": [
        "nsis",
        "zip",
        "portable"
      ]
    },
    "publish": {
      "provider": "github",
      "releaseType": "draft"
    }
  }
}
